{
  "include": ["src"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "types": ["@jxa/types", "@jxa/global-type", "node", "fs-extra"],
    "noImplicitAny": false,
    "declaration": true
  }
}
