{
  "name": "mac-helper",
  "type": "module",
  "version": "0.8.1",
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "description": "useful helper for macOS",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/mac-helper#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/mac-helper.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/mac-helper/issues"
  },
  "keywords": [
    "mac",
    "helper",
    "mac-helper"
  ],
  "exports": {
    "types": "./lib/index.d.ts",
    "default": "./lib/index.js"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "prepare": "husky",
    "test": "vitest run --globals --testTimeout=30000",
    "test:dev": "vitest --globals --testTimeout=30000",
    "test-cover": "vitest run --globals --coverage --testTimeout=30000",
    "dev": "tsgo -w --incremental",
    "typecheck": "tsgo --noEmit",
    "build": "rm -rf lib; tsgo",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "@jxa/run": "^1.4.0",
    "es-toolkit": "^1.47.0",
    "promise.map": "^1.2.0"
  },
  "devDependencies": {
    "@jxa/global-type": "^1.4.0",
    "@jxa/sdef-to-dts": "^1.4.0",
    "@jxa/types": "^1.4.0",
    "@magicdawn/eslint-config": "github:magicdawn/eslint-config#dist",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "@vitest/coverage-v8": "^4.1.7",
    "delay": "^7.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.5",
    "husky": "^9.1.7",
    "jxa-common-used": "^0.0.3",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "should": "^13.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,less,md}": [
      "prettier --write"
    ]
  }
}
