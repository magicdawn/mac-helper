{
  "name": "mac-helper",
  "type": "module",
  "version": "0.10.0",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "description": "useful helper for macOS",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/mac-helper#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/mac-helper.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/mac-helper/issues"
  },
  "keywords": [
    "mac",
    "helper",
    "mac-helper"
  ],
  "exports": {
    "types": "./lib/index.d.ts",
    "default": "./lib/index.js"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "prepare": "husky",
    "test": "vitest run --globals --testTimeout=30000",
    "test:dev": "vitest --globals --testTimeout=30000",
    "test-cover": "vitest run --globals --coverage --testTimeout=30000",
    "dev": "tsgo -w --incremental",
    "typecheck": "tsgo --noEmit",
    "build": "rm -rf lib; tsgo",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "dedent": "^1.7.2",
    "es-toolkit": "^1.47.1",
    "promise.map": "^1.2.0",
    "run-applescript": "^7.1.0",
    "run-jxa": "^4.0.0"
  },
  "devDependencies": {
    "@jxa/global-type": "^1.4.0",
    "@jxa/sdef-to-dts": "^1.4.0",
    "@jxa/types": "^1.4.0",
    "@magicdawn/eslint-config": "^1.6.8",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.4",
    "@typescript/native-preview": "7.0.0-dev.20260620.1",
    "@vitest/coverage-v8": "^4.1.9",
    "delay": "^7.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.5",
    "husky": "^9.1.7",
    "jxa-common-used": "^0.0.3",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "should": "^13.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write --ignore-unknown"
    ],
    "!*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
