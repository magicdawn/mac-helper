{
  "name": "mac-helper",
  "version": "0.8.1",
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "description": "useful helper for macOS",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/mac-helper#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/mac-helper.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/mac-helper/issues"
  },
  "keywords": [
    "mac",
    "helper",
    "mac-helper"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/",
    "src/"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "prepare": "husky",
    "test": "vitest run --globals --testTimeout=30000",
    "test:dev": "vitest --globals --testTimeout=30000",
    "test-cover": "vitest run --globals --coverage --testTimeout=30000",
    "dev": "tsc -w --incremental",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf lib; rm *.tsbuildinfo; tsc",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "@jxa/run": "^1.4.0",
    "es-toolkit": "^1.46.1",
    "promise.map": "^1.1.3"
  },
  "devDependencies": {
    "@jxa/global-type": "^1.4.0",
    "@jxa/sdef-to-dts": "^1.4.0",
    "@jxa/types": "^1.4.0",
    "@magicdawn/eslint-config": "^1.6.5",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "delay": "^7.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.5",
    "husky": "^9.1.7",
    "jxa-common-used": "^0.0.3",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "should": "^13.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,less,md}": [
      "prettier --write"
    ]
  }
}
