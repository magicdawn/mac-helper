{
  "name": "mac-helper",
  "version": "0.6.0",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "description": "useful helper for macOS",
  "keywords": [
    "mac",
    "helper",
    "mac-helper"
  ],
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/mac-helper#readme",
  "bugs": {
    "url": "https://github.com/magicdawn/mac-helper/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/mac-helper.git"
  },
  "author": "magicdawn",
  "files": [
    "lib/",
    "src/"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "prepare": "husky",
    "test": "vitest run --globals --testTimeout=30000",
    "test:dev": "vitest --globals --testTimeout=30000",
    "test-cover": "vitest run --globals --coverage --testTimeout=30000",
    "dev": "tsc -w --incremental",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf lib; rm *.tsbuildinfo; tsc",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "@jxa/run": "^1.4.0",
    "es-toolkit": "^1.45.1",
    "promise.map": "^1.1.3"
  },
  "devDependencies": {
    "@jxa/global-type": "^1.4.0",
    "@jxa/sdef-to-dts": "^1.4.0",
    "@jxa/types": "^1.4.0",
    "@magicdawn/eslint-config": "^1.6.2",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "delay": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.4",
    "husky": "^9.1.7",
    "jxa-common-used": "^0.0.3",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "should": "^13.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "core-js",
      "es5-ext",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,less,md}": [
      "prettier --write"
    ]
  }
}
