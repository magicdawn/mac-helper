{
  "name": "mac-helper",
  "version": "0.5.0",
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
  "description": "useful helper for macOS",
  "keywords": [
    "mac",
    "helper",
    "mac-helper"
  ],
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/mac-helper#readme",
  "bugs": {
    "url": "https://github.com/magicdawn/mac-helper/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/mac-helper.git"
  },
  "author": "magicdawn",
  "files": [
    "lib/",
    "src/"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "prepare": "husky",
    "test": "vitest run --globals --testTimeout=30000",
    "test:dev": "vitest --globals --testTimeout=30000",
    "test-cover": "vitest run --globals --coverage --testTimeout=30000",
    "dev": "tsc -w --incremental",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf lib; rm *.tsbuildinfo; tsc",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "@jxa/run": "^1.4.0",
    "es-toolkit": "^1.44.0",
    "promise.map": "^1.1.3"
  },
  "devDependencies": {
    "@jxa/global-type": "^1.4.0",
    "@jxa/sdef-to-dts": "^1.4.0",
    "@jxa/types": "^1.4.0",
    "@magicdawn/eslint-config": "^1.6.1",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "delay": "^7.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.3",
    "husky": "^9.1.7",
    "jxa-common-used": "^0.0.3",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "should": "^13.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "core-js",
      "es5-ext",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,less,md}": [
      "prettier --write"
    ]
  }
}
